generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ─────────────────────────────────────

enum EstadoEntrega {
  PENDIENTE
  EN_REVISION
  REQUIERE_CORRECCION
  APROBADO
  NO_APROBADO
  NO_ENTREGADO
  EXENTO
  ENTREGADO_FISICO
}

enum TipoPeriodo {
  ANUAL
  SEMESTRAL
  MENSUAL
}

// ─── Models ────────────────────────────────────

model Admin {
  id           String       @id @default(cuid())
  email        String       @unique
  password     String
  nombre       String
  role         String       @default("ATP_LECTOR")
  permisos     Json?
  correcciones Correccion[]
}

model Escuela {
  id        String   @id @default(cuid())
  cct       String   @unique
  nombre    String
  localidad String
  municipio    String?
  zonaEscolar  String?
  codigoPostal String?
  email     String   @unique
  password  String
  director  String?
  hombres   Int      @default(0)
  mujeres   Int      @default(0)
  total     Int      @default(0)
  rol       String   @default("director")
  ultimoIngreso DateTime?
  geminiApiKey  String?
  esDePrueba    Boolean  @default(false)
  esSupervision Boolean  @default(false)
  permisos      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entregas Entrega[]
  configuraciones ConfiguracionPrograma[]
  inscripcionesEventos InscripcionEvento[]
  inscripcionesOlimpiadas InscripcionOlimpiada[]
  inscripcionesPAEC InscripcionEncuentroPAEC[]
  descargasCircular05 Circular05Descarga[]
  capemRegistros CapemFichaRegistro[]
  personal Personal[]
  directorExpediente DirectorExpediente?
  documentosAdmin DocumentoAdministrativo[]
  
  // ─── Generador de Horarios con IA ───
  horarioConfiguracion HorarioConfiguracion?
  horariosGenerados HorarioGenerado[]
  horarioGrupos HorarioGrupo[]
  horarioAulas HorarioAula[]
  horarioAsignaturasHorario HorarioAsignaturaCatalogo[]
  horarioCargas HorarioCargaDocente[]
}

model CicloEscolar {
  id     String   @id @default(cuid())
  nombre String   @unique // "2025-2026"
  inicio DateTime // 2025-08-01
  fin    DateTime // 2026-07-31
  activo Boolean  @default(true)
  anuncioGlobal String?

  periodos PeriodoEntrega[]
  capems   Capem[]
  inscripcionesEventos     InscripcionEvento[]
  inscripcionesOlimpiadas  InscripcionOlimpiada[]
  inscripcionesPAEC        InscripcionEncuentroPAEC[]
  descargasCircular05      Circular05Descarga[]
  horariosGenerados        HorarioGenerado[]
}

model Programa {
  id               String           @id @default(cuid())
  nombre           String           @unique
  descripcion      String?
  tipo             TipoPeriodo      @default(ANUAL)
  numArchivos      Int              @default(1) // Día Naranja = 2
  orden            Int              @default(0)
  etiquetasArchivos String[]       @default([])
  recordatorioAuto Boolean          @default(false)
  esParaSupervision Boolean         @default(false)
  createdAt        DateTime         @default(now())

  periodos PeriodoEntrega[]
  recursos Recurso[]
  configuraciones ConfiguracionPrograma[]
}

model PeriodoEntrega {
  id             String   @id @default(cuid())
  cicloEscolarId String
  programaId     String
  mes            Int?     // 1-12 para MENSUAL
  semestre       Int?     // 1 o 2 para SEMESTRAL
  activo         Boolean  @default(true)
  fechaLimite    DateTime?
  createdAt      DateTime @default(now())

  cicloEscolar CicloEscolar @relation(fields: [cicloEscolarId], references: [id])
  programa     Programa     @relation(fields: [programaId], references: [id])
  entregas     Entrega[]

  @@unique([cicloEscolarId, programaId, mes, semestre])
}

model Entrega {
  id               String         @id @default(cuid())
  escuelaId        String
  periodoEntregaId String
  estado           EstadoEntrega  @default(NO_ENTREGADO)
  observacionesATP String?
  fechaSubida      DateTime?
  fechaRevision    DateTime?
  firmaDigital     String?
  cvd              String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  escuela        Escuela        @relation(fields: [escuelaId], references: [id], onDelete: Cascade)
  periodoEntrega PeriodoEntrega @relation(fields: [periodoEntregaId], references: [id])
  archivos       Archivo[]
  correcciones   Correccion[]
  preRevision    PreRevision?
  chatMensajes   ChatMensaje[]

  @@unique([escuelaId, periodoEntregaId])
}

model Archivo {
  id        String   @id @default(cuid())
  entregaId String
  nombre    String
  driveId   String?
  driveUrl  String?
  tipo      String   @default("ENTREGA") // ENTREGA | CORRECCION
  subidoPor String   @default("director") // director | atp
  etiqueta  String?  // "Registro", "Evidencias" (Día Naranja)
  createdAt DateTime @default(now())

  entrega    Entrega     @relation(fields: [entregaId], references: [id], onDelete: Cascade)
  correccion Correccion?
}

model Correccion {
  id         String   @id @default(cuid())
  entregaId  String
  texto      String?
  archivoId  String?  @unique
  adminId    String
  createdAt  DateTime @default(now())

  entrega  Entrega  @relation(fields: [entregaId], references: [id], onDelete: Cascade)
  archivo  Archivo? @relation(fields: [archivoId], references: [id])
  admin    Admin    @relation(fields: [adminId], references: [id])
}

model Recurso {
  id            String   @id @default(cuid())
  titulo        String
  descripcion   String?
  archivoNombre String
  archivoDriveId  String?
  archivoDriveUrl String?
  programaId    String?
  createdAt     DateTime @default(now())

  programa Programa? @relation(fields: [programaId], references: [id])
}

model ConfiguracionPrograma {
  id          String   @id @default(cuid())
  escuelaId   String
  programaId  String
  numArchivos Int      @default(1)
  createdAt   DateTime @default(now())

  escuela     Escuela  @relation(fields: [escuelaId], references: [id], onDelete: Cascade)
  programa    Programa @relation(fields: [programaId], references: [id], onDelete: Cascade)

  @@unique([escuelaId, programaId])
}

// ─── Eventos Culturales 2026 ─────────────────────

model CategoriaEvento {
  id          String   @id @default(cuid())
  nombre      String   @unique
  color       String   @default("#2e75b6")
  orden       Int      @default(0)
  createdAt   DateTime @default(now())

  disciplinas DisciplinaEvento[]
}

model DisciplinaEvento {
  id               String   @id @default(cuid())
  categoriaId      String
  nombre           String
  tipo             String   // "simple" | "individual" | "equipo" | "grupo"
  minParticipantes Int      @default(1)
  maxParticipantes Int      @default(1)
  grupoExclusion   String?  // ID de grupo para exclusión mutua (ej. "canto")
  orden            Int      @default(0)
  createdAt        DateTime @default(now())

  categoria        CategoriaEvento @relation(fields: [categoriaId], references: [id], onDelete: Cascade)
}

model EventosConfig {
  id          String    @id @default("singleton")
  activo      Boolean   @default(false)
  fechaLimite DateTime?
}

model InscripcionEvento {
  id             String   @id @default(cuid())
  escuelaId      String
  cicloEscolarId String
  datos          Json     // { [disciplinaId]: { participa: boolean, numParticipantes: number } }
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())

  escuela      Escuela      @relation(fields: [escuelaId], references: [id], onDelete: Cascade)
  cicloEscolar CicloEscolar @relation(fields: [cicloEscolarId], references: [id], onDelete: Cascade)

  @@unique([escuelaId, cicloEscolarId])
  @@map("InscripcionEvento2026")
}

// ─── Proyecto Circular 05 ────────────────────────

model Circular05Config {
  id                String  @id @default("singleton")
  activo            Boolean @default(false)
  destinatario      String  @default("ING. ALEJANDRO ESCAMILLA MARTINEZ")
  cargoDestinatario String  @default("SUPERVISOR ESCOLAR DE BACHILLERATOS GENERALES")
  zonaDestinatario  String  @default("ZONA 004, VENUSTIANO CARRANZA PUEBLA")
}

model Circular05Descarga {
  id             String   @id @default(cuid())
  escuelaId      String
  cicloEscolarId String
  datos          Json
  createdAt      DateTime @default(now())

  escuela      Escuela      @relation(fields: [escuelaId], references: [id], onDelete: Cascade)
  cicloEscolar CicloEscolar @relation(fields: [cicloEscolarId], references: [id], onDelete: Cascade)
}

model Circular05Disciplina {
  id     String  @id @default(cuid())
  nombre String  @unique
  area   String  @default("")
  activo Boolean @default(true)
  orden  Int     @default(0)
}

// ─── Olimpiada de Matemáticas 2026 ───────────────

model OlimpiadaConfig {
  id              String    @id @default("singleton")
  activo          Boolean   @default(false)
  convocatoriaUrl String?
  fechaLimite     DateTime?
}

model InscripcionOlimpiada {
  id             String   @id @default(cuid())
  escuelaId      String
  cicloEscolarId String
  datos          Json     // { alumnos: [{nombre, grado, curp}] }
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())

  escuela      Escuela      @relation(fields: [escuelaId], references: [id], onDelete: Cascade)
  cicloEscolar CicloEscolar @relation(fields: [cicloEscolarId], references: [id], onDelete: Cascade)

  @@unique([escuelaId, cicloEscolarId])
}

// ─── Encuentro PAEC 2026 ────────────────────────

model EncuentroPAECConfig {
  id               String    @id @default("singleton")
  activo           Boolean   @default(false)
  convocatoriaUrl  String?
  encuentroUrl     String?
  fechaLimite      DateTime?
}

model InscripcionEncuentroPAEC {
  id             String   @id @default(cuid())
  escuelaId      String
  cicloEscolarId String
  datos          Json     // { nombreProyecto, problematicaEntorno, alumnos: [{nombre, grado, curp}] }
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())

  escuela      Escuela      @relation(fields: [escuelaId], references: [id], onDelete: Cascade)
  cicloEscolar CicloEscolar @relation(fields: [cicloEscolarId], references: [id], onDelete: Cascade)

  @@unique([escuelaId, cicloEscolarId])
}

// ─── Configuración de Visibilidad del Sidebar Admin ──

model AdminSidebarConfig {
  id              String  @id @default("singleton")
  showRecursos    Boolean @default(true)
  showEventos     Boolean @default(true)
  showCircular05  Boolean @default(true)
  showOlimpiada   Boolean @default(true)
  showPAEC        Boolean @default(true)
  showCapems      Boolean @default(true)
  showExpedientes Boolean @default(true)
}

// ─── Autoridades Educativas (Constancias) ────────

model AutoridadesConfig {
  id                  String @id @default("singleton")
  supervisor          String @default("C. SUPERVISOR(A)")
  supervisorRFC       String @default("")
  supervisorFecha     String @default("")
  supervisorClave     String @default("")

  coordinadorRegional String @default("C. COORDINADOR(A) REGIONAL")
  directorNivel       String @default("C. DIRECTOR(A) DEL NIVEL")

  atp1Nombre          String @default("")
  atp1RFC             String @default("")
  atp1Fecha           String @default("")
  atp1Clave           String @default("")

  atp2Nombre          String @default("")
  atp2RFC             String @default("")
  atp2Fecha           String @default("")
  atp2Clave           String @default("")

  atp3Nombre          String @default("")
  atp3RFC             String @default("")
  atp3Fecha           String @default("")
  atp3Clave           String @default("")

  atp4Nombre          String @default("")
  atp4RFC             String @default("")
  atp4Fecha           String @default("")
  atp4Clave           String @default("")
}

// ─── CAPEMS ─────────────────────────────────────────

model Ficha {
  id        String   @id @default(cuid())
  nombre    String   @unique
  activo    Boolean  @default(true)
  orden     Int      @default(0)
  createdAt DateTime @default(now())

  registros CapemFichaRegistro[]
}

model Capem {
  id             String   @id @default(cuid())
  nombre         String
  orden          Int      @default(0)
  activo         Boolean  @default(true)
  cicloEscolarId String
  createdAt      DateTime @default(now())

  cicloEscolar CicloEscolar        @relation(fields: [cicloEscolarId], references: [id])
  registros    CapemFichaRegistro[]

  @@unique([cicloEscolarId, nombre])
}

model CapemsConfig {
  id          String    @id @default("singleton")
  activo      Boolean   @default(false)
  fechaLimite DateTime?
}

model CapemFichaRegistro {
  id              String   @id @default(cuid())
  escuelaId       String
  capemId         String
  fichaId         String
  archivoNombre   String?
  archivoDriveId  String?
  archivoDriveUrl String?
  bloqueado       Boolean  @default(false)
  validoIA        String?  // "APROBADO" | "ADVERTENCIA" | "RECHAZADO" | "PENDIENTE"
  observacionesIA String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  escuela Escuela @relation(fields: [escuelaId], references: [id], onDelete: Cascade)
  capem   Capem   @relation(fields: [capemId], references: [id], onDelete: Cascade)
  ficha   Ficha   @relation(fields: [fichaId], references: [id])
}

// ─── Expedientes de Personal ──────────────────────────

model ExpedientesConfig {
  id     String  @id @default("singleton")
  activo Boolean @default(false)
}

model Personal {
  id               String   @id @default(cuid())
  escuelaId        String
  nombre           String   // Nombre(s)
  apellidoPaterno  String
  apellidoMaterno  String
  sexo             String   // "MASCULINO" | "FEMENINO"
  cargo            String   // "RESPONSABLE" | "DOCENTE" | "ADMINISTRATIVO" | "APOYO"
  curp             String?
  rfc              String?
  telefono         String?
  correoElectronico String?
  gradoAcademico   String?  // "LICENCIATURA" | "MAESTRIA" | "DOCTORADO" | "OTRO"
  fechaIngreso     DateTime?
  clavePresupuestal String?
  orden            Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  escuela    Escuela             @relation(fields: [escuelaId], references: [id], onDelete: Cascade)
  documentos DocumentoPersonal[]
  documentosAdmin DocumentoAdministrativo[]
  horarioCargas   HorarioCargaDocente[]
  horarioCeldas   HorarioCelda[]
}

model DocumentoPersonal {
  id               String   @id @default(cuid())
  personalId       String
  tipoDocumento    String   // "TITULO", "CEDULA", "ACTA_NACIMIENTO", "CURP", etc. o "CUSTOM"
  etiqueta         String?  // Nombre personalizado para documentos extra
  archivoNombre    String?
  archivoDriveId   String?
  archivoDriveUrl  String?
  bloqueado        Boolean  @default(false)
  validoIA         String?  // "APROBADO" | "ADVERTENCIA" | "RECHAZADO" | "PENDIENTE"
  observacionesIA  String?
  noTiene          Boolean  @default(false)
  orden            Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  personal         Personal @relation(fields: [personalId], references: [id], onDelete: Cascade)
}

model PreRevision {
  id             String   @id @default(cuid())
  entregaId      String   @unique
  resultado      Json     // Contiene { cumpleFirmas: boolean, borradorCorreo: string, etc. }
  intentosUsados Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  entrega   Entrega  @relation(fields: [entregaId], references: [id], onDelete: Cascade)
}

model PreRevisionConfig {
  id              String  @id @default("singleton")
  activoDirectores Boolean @default(false)
  mantenimiento   Boolean @default(false)
  limiteIntentos  Int     @default(3)
  providerDefault String  @default("gemini")
  modelDefault    String  @default("gemini-2.5-flash")
  providerPremium String  @default("gemini")
  modelPremium    String  @default("gemini-2.5-pro")
}

model PlantillaEvaluacion {
  id        String   @id @default(cuid())
  modulo    String   // "PMC" | "PAEC"
  nombre    String   // ej. "Rúbrica de Diagnóstico Colectivo 2025"
  contenido String   // El prompt maestro, lineamientos o rúbrica completa
  activo    Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

model ApiKey {
  id          String   @id @default(cuid())
  provider    String   // "gemini" | "openai" | "claude" | "openrouter" | "deepseek"
  key         String
  label       String
  active      Boolean  @default(true)
  errorCount  Int      @default(0)
  isPremium   Boolean  @default(false)
  usageCount  Int      @default(0)
  lastUsedAt  DateTime?
  lastModel   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ChatMensaje {
  id        String   @id @default(cuid())
  entregaId String
  role      String   // "user" | "assistant"
  content   String
  createdAt DateTime @default(now())

  entrega   Entrega  @relation(fields: [entregaId], references: [id], onDelete: Cascade)
}

// ─── Documentos Administrativos ──────────────────

model DirectorExpediente {
  id                 String    @id @default(cuid())
  nombreCompleto     String
  rfc                String?
  curp               String?
  fechaIngreso       DateTime?
  clavePresupuestal  String?
  telefono           String?
  correo             String?
  
  // Relación con su escuela actual (una o ninguna si está en transición)
  escuelaActualId    String?   @unique
  escuelaActual      Escuela?  @relation(fields: [escuelaActualId], references: [id])
  
  // Historial y Documentos
  documentosGenerados DocumentoAdministrativo[]
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model PlantillaDocumento {
  id                  String   @id @default(cuid())
  nombre              String   // Ej. "Constancia de No Adeudo 2025"
  archivoNombre       String   // Nombre del docx original
  archivoDriveId      String   // Cloudinary public_id
  archivoDriveUrl     String   // Cloudinary URL
  hash                String   // Para detectar subidas del mismo archivo
  estado              String   @default("NUEVA") // NUEVA | CONFIGURADA
  configuracionCampos Json?    // Mapeo detectado por IA y aprobado por Admin
  tiposDestinatario   String[] @default([]) // ["DIRECTOR","ATP","PERSONAL"]

  documentosGenerados DocumentoAdministrativo[]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model DocumentoAdministrativo {
  id                 String   @id @default(cuid())
  tipo               String   // Ej. "CONSTANCIA_NO_ADEUDO"
  plantillaId        String
  directorId         String?
  personalId         String?
  escuelaId          String?
  generadoPorId      String   // ID de Admin o Director que lo generó
  datosUtilizados    Json     // Los datos congelados al momento de generar
  archivoWordId      String?  // Cloudinary ID del doc generado
  archivoWordUrl     String?
  archivoPdfId       String?  // Cloudinary ID del PDF generado
  archivoPdfUrl      String?
  createdAt          DateTime @default(now())

  plantilla          PlantillaDocumento @relation(fields: [plantillaId], references: [id])
  director           DirectorExpediente? @relation(fields: [directorId], references: [id])
  personal           Personal? @relation(fields: [personalId], references: [id])
  escuela            Escuela? @relation(fields: [escuelaId], references: [id])
}

// ─── Generador de Horarios con IA ──────────────────

model HorarioAsignaturaCatalogo {
  id              String   @id @default(cuid())
  escuelaId       String?  // NULL = Catálogo oficial MCCEMS 203 UACs. Si tiene ID = Materia personalizada
  uacName         String
  semester        Int      // 1 al 6
  component       String   // "fundamental", "ext_obligatorio", "ext_optativo", "laboral"
  totalHours      Int      @default(48)
  horasSemanales  Int      @default(3)
  colorHex        String   @default("#3b82f6")
  createdAt       DateTime @default(now())

  escuela         Escuela? @relation(fields: [escuelaId], references: [id], onDelete: Cascade)
  asignaciones    HorarioCargaDocente[]
  celdas          HorarioCelda[]
}

model HorarioConfiguracion {
  id                  String   @id @default(cuid())
  escuelaId           String   @unique
  diasLectivos        Int      @default(5)
  horasPorDia         Int      @default(7)
  horaInicio          String   @default("08:00")
  duracionMinutos     Int      @default(50)
  recesoTrasPeriodo   Int      @default(3)
  duracionReceso      Int      @default(20)

  escuela             Escuela  @relation(fields: [escuelaId], references: [id], onDelete: Cascade)
}

model HorarioAula {
  id           String   @id @default(cuid())
  escuelaId    String
  nombre       String   // Ej. "Laboratorio de Cómputo", "Aula 1A"
  tipo         String   @default("REGULAR")
  capacidad    Int?     @default(40)

  escuela      Escuela  @relation(fields: [escuelaId], references: [id], onDelete: Cascade)
  celdas       HorarioCelda[]
}

model HorarioGrupo {
  id           String   @id @default(cuid())
  escuelaId    String
  nombre       String   // Ej. "1° A", "2° A", "3° A"
  semestre             Int      // 1 a 6
  turno                String   @default("MATUTINO")
  capacitacionNombre   String?  // Capacitación elegida para este grupo (3° a 6°)
  ffeOptativas         Json?    // Array de 4 optativas FFE para este grupo (5° y 6°)
  ffeoSocioemocional   String?  // Asignatura de Formación Socioemocional elegida para este grupo

  escuela      Escuela  @relation(fields: [escuelaId], references: [id], onDelete: Cascade)
  asignaciones HorarioCargaDocente[]
  celdas       HorarioCelda[]

  @@unique([escuelaId, nombre])
}

model HorarioCargaDocente {
  id                   String   @id @default(cuid())
  escuelaId            String
  personalId           String   // Relación con Personal (Docente)
  grupoId              String
  asignaturaId         String
  horasSemanales       Int      @default(3)
  esHoraDoblePermitida Boolean  @default(true)
  requiereAulaEspecial Boolean  @default(false)
  aulaEspecialId       String?

  escuela              Escuela                    @relation(fields: [escuelaId], references: [id], onDelete: Cascade)
  personal             Personal                   @relation(fields: [personalId], references: [id], onDelete: Cascade)
  grupo                HorarioGrupo               @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  asignatura           HorarioAsignaturaCatalogo  @relation(fields: [asignaturaId], references: [id], onDelete: Cascade)
  celdas               HorarioCelda[]
}

model HorarioGenerado {
  id             String   @id @default(cuid())
  escuelaId      String
  cicloEscolarId String
  nombreVersion  String   @default("Borrador 1")
  estado         String   @default("BORRADOR") // "BORRADOR" | "PUBLICADO"
  scoreMetricas  Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  escuela        Escuela          @relation(fields: [escuelaId], references: [id], onDelete: Cascade)
  cicloEscolar   CicloEscolar     @relation(fields: [cicloEscolarId], references: [id], onDelete: Cascade)
  celdas         HorarioCelda[]
  mensajesChat   HorarioChatMensaje[]
}

model HorarioCelda {
  id             String   @id @default(cuid())
  horarioId      String
  diaSemana      Int      // 1: Lunes ... 5: Viernes
  periodo        Int      // 1 a N
  grupoId        String
  docenteId      String
  asignaturaId   String
  aulaId         String?
  cargaId        String?
  esBloqueado    Boolean  @default(false)

  horario        HorarioGenerado       @relation(fields: [horarioId], references: [id], onDelete: Cascade)
  grupo          HorarioGrupo          @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  docente        Personal              @relation(fields: [docenteId], references: [id], onDelete: Cascade)
  asignatura     HorarioAsignaturaCatalogo @relation(fields: [asignaturaId], references: [id], onDelete: Cascade)
  aula           HorarioAula?          @relation(fields: [aulaId], references: [id], onDelete: SetNull)
  carga          HorarioCargaDocente?  @relation(fields: [cargaId], references: [id], onDelete: SetNull)
}

model HorarioChatMensaje {
  id             String   @id @default(cuid())
  horarioId      String
  role           String   // "user" | "assistant"
  content        String
  accionAplicada Json?
  createdAt      DateTime @default(now())

  horario        HorarioGenerado @relation(fields: [horarioId], references: [id], onDelete: Cascade)
}

